# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave DATABASE_URL unset to fall back to sqlite at db.sqlite3)
# DATABASE_URL=postgres://osbakery:osbakery@localhost:5432/osbakery

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
# Local: artifacts land under ./storage/artifacts
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_STORAGE_ROOT=./storage/artifacts

# S3 (set ARTIFACT_STORAGE_BACKEND=s3 to enable)
# AWS_STORAGE_BUCKET_NAME=os-bakery-artifacts
# AWS_S3_ENDPOINT_URL=https://s3.eu-central-1.amazonaws.com
# AWS_S3_REGION_NAME=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Build orchestration
PACKER_BIN=packer
PACKER_TEMPLATES_ROOT=./packer
SALT_STATES_ROOT=./salt/states
SALT_PILLAR_ROOT=./salt/pillar
BUILD_WORK_ROOT=./storage/work
DOWNLOAD_TOKEN_TTL_HOURS=72

# packer-arm-tools provisioner
# Set to true once the cznewt/packer-arm-tools Docker image is available on
# the worker host (requires Docker + --privileged + /dev mount at runtime).
PACKER_ARM_TOOLS_ENABLED=false
# PACKER_ARM_TOOLS_IMAGE=docker.io/cznewt/packer-arm-tools:latest

# Salt master settings — used by the packer-arm-tools salt-minion variants.
# SALT_MASTER_URL=salt-master.example.com
# SALT_MINION_VERSION=3007

# HTTP pillar endpoint (GET /pillar/<minion_id>) — consumed by a Salt master
# via salt.pillar.http_json. Credentials the master presents as HTTP Basic.
# Leave unset for an open endpoint (dev); set BOTH in production — the pillar
# carries secrets (WireGuard/ZeroTier keys, repo creds).
# SALT_PILLAR_USERNAME=salt
# SALT_PILLAR_PASSWORD=change-me

# Local compose stack defaults (compose.yaml wires these per service —
# duplicated here for the bare `manage.py runserver` workflow).
#
# Web defaults inside compose:
#   DATABASE_URL=postgres://osbakery:osbakery@postgres:5432/osbakery
#   CELERY_BROKER_URL=redis://redis:6379/0
#   ARTIFACT_STORAGE_BACKEND=s3
#   AWS_S3_ENDPOINT_URL=http://minio:9000
#   AWS_ACCESS_KEY_ID=osbakery
#   AWS_SECRET_ACCESS_KEY=osbakery-secret
#   AWS_STORAGE_BUCKET_NAME=os-bakery-artifacts
#   SALT_MASTER_URL=salt-master
#
# MinIO root credentials (for the console at http://localhost:9001):
#   user: osbakery
#   pass: osbakery-secret
