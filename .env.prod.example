# Production .env for compose.prod.yaml — copy to `.env` on the host and fill in.
#   cp .env.prod.example .env && edit .env
#
# Values marked REQUIRED have no safe default; compose will refuse to start
# without them (the `:?` guards in compose.prod.yaml).

# ── Prebuilt image selection ────────────────────────────────────────────────
# Registry namespace and tag for the GHCR images published by docker.yml.
OSBAKERY_REGISTRY=ghcr.io/cznewt
OSBAKERY_IMAGE_TAG=latest

# ── Django ──────────────────────────────────────────────────────────────────
# REQUIRED: generate with `python -c "import secrets;print(secrets.token_urlsafe(64))"`
DJANGO_SECRET_KEY=
# Keep false in prod. Setting true is a stopgap to get styled /static/ without
# a reverse proxy — it also exposes tracebacks, so don't leave it on.
DJANGO_DEBUG=false
# Must include the host's address / DNS name, plus the compose service name.
DJANGO_ALLOWED_HOSTS=10.50.20.226,localhost,127.0.0.1,web

# gunicorn tuning (optional)
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60

# ── Postgres ────────────────────────────────────────────────────────────────
# REQUIRED: also embedded into DATABASE_URL by compose.prod.yaml.
POSTGRES_PASSWORD=

# ── MinIO / S3 artifact store ────────────────────────────────────────────────
MINIO_ROOT_USER=osbakery
# REQUIRED: used as both the MinIO root password and the app's S3 secret key.
MINIO_ROOT_PASSWORD=
# Browser-reachable base URL of the artifact bucket's S3 API (host:9000). When
# set, mirrored base images link straight to the S3 object. The bucket is
# anonymous-download, so no auth needed for GETs.
AWS_S3_PUBLIC_ENDPOINT=http://10.50.20.226:9000

# ── Celery ──────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=2

# ── Notes ────────────────────────────────────────────────────────────────────
# * The Salt master starts with an empty state/pillar tree (the repo isn't
#   checked out on the host). To serve custom states, either bind-mount a
#   states dir into the salt-master service or push states out-of-band.
# * worker-packer-arm and worker-esphome are intentionally absent — no
#   published images. See the header of compose.prod.yaml.
